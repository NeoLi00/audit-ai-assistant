# No-Docker macOS/local profile.
# Copy with: make local-env

APP_NAME=审计 AI 助手平台
APP_ENV=local
API_PREFIX=/api
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTO_CREATE_TABLES=true
PROCESS_DOCUMENTS_INLINE=true

VITE_API_BASE_URL=http://localhost:8000/api

# SQLite keeps local smoke testing independent of Docker/PostgreSQL.
DATABASE_URL=sqlite:///./audit_ai_local.db

# Redis/Celery are not required when PROCESS_DOCUMENTS_INLINE=true.
REDIS_URL=redis://localhost:16379/0
CELERY_BROKER_URL=redis://localhost:16379/1
CELERY_RESULT_BACKEND=redis://localhost:16379/2

# Uploads use local filesystem fallback unless you enable MinIO.
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=audit-documents
MINIO_SECURE=false
USE_LOCAL_STORAGE_FALLBACK=true
LOCAL_STORAGE_DIR=.local_storage

# Vector search uses in-process fallback for local smoke testing.
QDRANT_URL=http://localhost:16333
QDRANT_COLLECTION=audit_chunks
ENABLE_OPENSEARCH=false
OPENSEARCH_URL=http://localhost:19200

LLM_PROVIDER=school_qwen
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen
LLM_TIMEOUT=120
LLM_STREAM=true
USE_MOCK_LLM=true

EMBED_PROVIDER=school_embedding
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=school-embedding
EMBED_DIM=1024
EMBED_BATCH_SIZE=16
EMBED_TIMEOUT=60
USE_MOCK_EMBEDDING=true

DOCUMENT_PARSER_PROVIDER=mineru
MINERU_COMMAND=mineru
MINERU_BACKEND=pipeline
MINERU_OUTPUT_DIR=.local_storage/mineru-output
MINERU_TIMEOUT=300

LOCAL_E5_MODEL=intfloat/multilingual-e5-small
LOCAL_E5_BASE_URL=http://127.0.0.1:18080/v1
LOCAL_E5_HOST=127.0.0.1
LOCAL_E5_PORT=18080

MAX_UPLOAD_MB=50
TEMP_FILE_TTL_HOURS=24
